{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "exec gunicorn --bind 0.0.0.0:${PORT} --workers 2 --worker-class gthread --threads 2 --timeout 120 --keepalive 5 --max-requests 1000 --max-requests-jitter 50 --log-level info --access-logfile - --error-logfile - app_dash:server",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
